{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "ui_kits/aeroscan-device/**",
              "ui_kits/aeroscan-device/screens/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Lato|Neuropol X|Sofachrome))/i]",
        "message": "Font not provided by the design system. Available: Lato, Neuropol X, Sofachrome."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|variant|dot|glow|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, variant, dot, glow, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|amber|teal|magenta|red|cyan|ble|wifi|muted)$/]",
        "message": "<Badge> tone must be one of 'green' | 'amber' | 'teal' | 'magenta' | 'red' | 'cyan' | 'ble' | 'wifi' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|outline)$/]",
        "message": "<Badge> variant must be one of 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|tone|selected|committed|disabled|icon|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, tone, selected, committed, disabled, icon, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:menu|solid|ghost)$/]",
        "message": "<Button> variant must be one of 'menu' | 'solid' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:teal|amber|magenta)$/]",
        "message": "<Button> tone must be one of 'teal' | 'amber' | 'magenta'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|indeterminate|disabled|onChange|label|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, indeterminate, disabled, onChange, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|align|width|key|ref|className|style|children)$/]",
        "message": "<DataColumn> doesn't accept that prop. Declared props: key, label, align, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<DataColumn> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MenuItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|secondLine|icon|selected|disabled|trailing|onClick|style|key|ref|className|style|children)$/]",
        "message": "<MenuItem> doesn't accept that prop. Declared props: label, secondLine, icon, selected, disabled, trailing, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MessageBoxButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|tone|onClick|key|ref|className|style|children)$/]",
        "message": "<MessageBoxButton> doesn't accept that prop. Declared props: label, tone, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='MessageBoxButton'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:teal|amber|magenta)$/]",
        "message": "<MessageBoxButton> tone must be one of 'teal' | 'amber' | 'magenta'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|trailing|children|scope|padded|style|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: title, trailing, children, scope, padded, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:iconBase|battery|wifi|gps|adsb|time|orientation|style|key|ref|className|style|children)$/]",
        "message": "<StatusBar> doesn't accept that prop. Declared props: iconBase, battery, wifi, gps, adsb, time, orientation, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBar'] > JSXAttribute[name.name='battery'] > Literal[value!=/^(?:full|mid|charging|unknown)$/]",
        "message": "<StatusBar> battery must be one of 'full' | 'mid' | 'charging' | 'unknown'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBar'] > JSXAttribute[name.name='wifi'] > Literal[value!=/^(?:conn_4bar|conn_2bar|connecting|disconnected|off)$/]",
        "message": "<StatusBar> wifi must be one of 'conn_4bar' | 'conn_2bar' | 'connecting' | 'disconnected' | 'off'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBar'] > JSXAttribute[name.name='gps'] > Literal[value!=/^(?:okay|nolock|off)$/]",
        "message": "<StatusBar> gps must be one of 'okay' | 'nolock' | 'off'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBar'] > JSXAttribute[name.name='adsb'] > Literal[value!=/^(?:on|off)$/]",
        "message": "<StatusBar> adsb must be one of 'on' | 'off'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBar'] > JSXAttribute[name.name='orientation'] > Literal[value!=/^(?:vertical|horizontal)$/]",
        "message": "<StatusBar> orientation must be one of 'vertical' | 'horizontal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|disabled|onChange|label|tone|style|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: checked, disabled, onChange, label, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:amber|teal|green)$/]",
        "message": "<Toggle> tone must be one of 'amber' | 'teal' | 'green'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
