<!-- Add these three lines inside the EXISTING <qresource prefix="/images"> block in
     aeroscan-gui/resources.qrc (next to av_logo.png). The asset paths are relative to
     resources.qrc, so copy the PNGs into aeroscan-gui/assets/ first. -->

        <file alias="parhelia_watermark.png">assets/parhelia_watermark.png</file>
        <file alias="parhelia_mark.png">assets/parhelia_mark.png</file>
        <file alias="parhelia_logo.png">assets/parhelia_logo.png</file>
